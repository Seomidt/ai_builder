# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Replit managed or Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ─── Supabase (server-side only) ──────────────────────────────────────────────
# Used for Supabase Auth and DB access from the server
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose client-side

# ─── GitHub (server-side only) ────────────────────────────────────────────────
# Personal Access Token or GitHub App token for repo operations
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─── OpenAI (server-side only) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ─── Vercel (server-side only, V2) ────────────────────────────────────────────
# Required in V2 for deployment automation
# VERCEL_TOKEN=your-vercel-token
# VERCEL_TEAM_ID=your-team-id
