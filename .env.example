# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Replit managed DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Used for Supabase Auth (identity layer). Service role key is server-only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NEVER expose client-side

# ─── GitHub (server-side only) ────────────────────────────────────────────────
# Personal Access Token with repo scope. Used for branch/file/PR operations.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-org-or-username          # optional default
GITHUB_REPO=your-repo-name                        # optional default
GITHUB_DEFAULT_BRANCH=main                        # optional, default: main

# ─── OpenAI (server-side only) ────────────────────────────────────────────────
# Required for Phase 2 AI agent execution. Never expose client-side.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ─── Default org (development only) ──────────────────────────────────────────
# Used when no Supabase auth token is present (demo/dev mode)
DEFAULT_ORG_ID=demo-org

# ─── Vercel (V2 — not yet implemented) ───────────────────────────────────────
# VERCEL_TOKEN=your-vercel-token
# VERCEL_TEAM_ID=your-team-id
